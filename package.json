{
  "name": "mern-login-fullstack",
  "private": true,
  "description": "Run API + Vite UI together",
  "scripts": {
    "dev": "concurrently -n api,ui -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:api": "npm run dev --prefix backend",
    "dev:ui": "npm run dev --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
